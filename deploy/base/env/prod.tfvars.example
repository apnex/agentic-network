# Base plan variables — foundation infrastructure (APIs, IAM, GCS bucket, Artifact Registry).
#
# Copy to `<env-name>.tfvars` and fill in values. Do NOT commit `<env>.tfvars`
# (excluded by deploy/.gitignore: env/*.tfvars).
#
# Per-env tfvars convention (mission-46 T1):
#   deploy/base/env/prod.tfvars        (the original env)
#   deploy/base/env/<other-env>.tfvars (new isolated tenants)
# Select which one `deploy/build-hub.sh` / `deploy/deploy-hub.sh` use via:
#   OIS_ENV=<env-name>   (default: prod if unset)

# ── Required per-env ─────────────────────────────────────────────────

project_id = "<your-gcp-project-id>"
region     = "<your-gcp-region>"

# ── Bucket name (GLOBALLY UNIQUE across GCP) ─────────────────────────
#
# GCS bucket names share a single global namespace. Per-env isolation
# requires a per-env bucket name — do NOT share "ois-relay-hub-state"
# across environments. Convention: "<project-id>-hub-state" or
# "ois-relay-hub-<env>-state" to guarantee uniqueness + readability.
#
# state_bucket_name  = "<your-project-hub-state>"
# environment        = "prod"                      # label attached to created resources; defaults to "prod"
# artifact_repo_name = "cloud-run-source-deploy"   # Artifact Registry repo name; defaults per env-neutral convention
