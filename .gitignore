# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo
*.tgz

# Mission-47 W1 exception: @ois/storage-provider ships its built dist/
# because hub depends on it via `file:../packages/storage-provider` and
# CI's `npm ci` doesn't install the package's devDependencies (typescript,
# @types/node), which the `prepare: tsc` hook would need to build on
# install. Committing dist/ is the pragmatic workaround until idea-186
# (npm workspaces migration) lands — once workspaces are in place, the
# build-on-install cascade works across devDependencies natively and
# this exception can be removed.
!packages/storage-provider/dist/
!packages/storage-provider/dist/**

# Mission-52 T3 exception (same workaround as storage-provider): hub
# depends on @ois/repo-event-bridge via file:../packages/repo-event-bridge,
# so the built dist/ ships alongside src/ until idea-186 lands.
!packages/repo-event-bridge/dist/
!packages/repo-event-bridge/dist/**

# Logs
*.log
.ois/

# Mission-47 T3 / Mission-48 — local-fs Hub state directory.
# Default OIS_LOCAL_FS_ROOT for `scripts/local/start-hub.sh` when
# STORAGE_BACKEND=local-fs. Populated by `scripts/state-sync.sh` from
# GCS, or grown organically by Hub during local-fs operation.
local-state/

